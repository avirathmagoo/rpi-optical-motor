[Unit]
Description=Motor Control UI
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/motor_control
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/pi/.Xauthority
ExecStart=/usr/bin/python3 /home/pi/motor_control/ui.py
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target
